<section class="filter-panel">

<h3 class="filter-label">Status</h3>
<nav class="status-filters">

  <%= link_to "All",
  issues_path(project_id: @project_id, query: @query, tag_id: @tag_id),
  class: (@status.nil? ? "active-filter" : nil) %>

  <%= link_to "Pending",
  issues_path(status: "Pending", project_id: @project_id, query: @query, tag_id: @tag_id),
  class: (@status == "Pending" ? "active-filter" : nil) %>

  <%= link_to "Investigating",
  issues_path(status: "Investigating", project_id: @project_id, query: @query, tag_id: @tag_id),
  class: (@status == "Investigating" ? "active-filter" : nil) %>

  <%= link_to "Resolved",
  issues_path(status: "Resolved", project_id: @project_id, query: @query, tag_id: @tag_id),
  class: (@status == "Resolved" ? "active-filter" : nil) %>

</nav>

<h3 class="filter-label">Projects</h3>
<nav class="project-filters">

  <%= link_to "All Projects",
  issues_path(status: @status, query: @query, tag_id: @tag_id),
  class: (@project_id.nil? ? "active-filter" : nil) %>

  <% Project.all.each do |project| %>

    <%= link_to project.name,
    issues_path(project_id: project.id, status: @status, query: @query, tag_id: @tag_id),
    class: (@project_id == project.id.to_s ? "active-filter" : nil) %>

  <% end %>

</nav>

<h3 class="filter-label">Tags</h3>
<nav class="tag-filters">

  <%= link_to "All Tags",
  issues_path(status: @status, project_id: @project_id, query: @query),
  class: (@tag_id.nil? ? "active-filter" : nil) %>

  <% Tag.order(:name).each do |tag| %>
    <%= link_to tag.name,
    issues_path(status: @status, project_id: @project_id, query: @query, tag_id: tag.id),
    class: (@tag_id == tag.id.to_s ? "active-filter" : nil) %>
  <% end %>

</nav>

<h3 class="filter-label">Search</h3>
<form class="search-form" method="get" action="/issues">

<%= hidden_field_tag :status, @status if @status.present? %>
<%= hidden_field_tag :project_id, @project_id if @project_id.present? %>
<%= hidden_field_tag :tag_id, @tag_id if @tag_id.present? %>

  <%= text_field_tag :query,
  params[:query],
  placeholder: "Search issues..." %>

  <%= submit_tag "Search" %>

</form>

<% if @status.present? || @project_id.present? || @query.present? || @tag_id.present? %>
  <section class="filter-summary">
    <p>
      Showing filtered results
      <% if @status.present? %>
        for status: <strong><%= @status %></strong>
      <% end %>

      <% if @project_id.present? %>
        <% selected_project = Project.find_by(id: @project_id) %>
        for project: <strong><%= selected_project&.name %></strong>
      <% end %>

      <% if @query.present? %>
        matching search: <strong><%= @query %></strong>
      <% end %>

      <% if @tag_id.present? %>
        <% selected_tag = Tag.find_by(id: @tag_id) %>
        for tag: <strong><%= selected_tag&.name %></strong>
      <% end %>
    </p>

    <%= link_to "Clear filters", issues_path %>
  </section>
<% end %>
</section>