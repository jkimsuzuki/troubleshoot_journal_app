<section class="filter-panel">
  <%= form_with url: issues_path, method: :get, local: true, class: "filter-form" do |form| %>

    <div class="filter-field">
      <%= form.label :status, "Status" %>
      <%= form.select :status,
        options_for_select(
          [
            ["All Statuses", ""],
            ["Pending", "Pending"],
            ["Active", "Investigating"],
            ["Resolved", "Resolved"]
          ],
          @status
        )
      %>
    </div>

    <div class="filter-field">
      <%= form.label :project_id, "Project" %>
      <%= form.collection_select :project_id,
        Project.order(:name),
        :id,
        :name,
        { include_blank: "All Projects", selected: @project_id }
      %>
    </div>

    <div class="filter-field">
      <%= form.label :tag_id, "Tag" %>
      <%= form.collection_select :tag_id,
        Tag.order(:name),
        :id,
        :name,
        { include_blank: "All Tags", selected: @tag_id }
      %>
    </div>

    <div class="filter-field filter-search">
      <%= form.label :query, "Search" %>
      <%= form.text_field :query,
        value: @query,
        placeholder: "Search issues..." %>
    </div>

    <div class="filter-actions">
      <%= form.submit "Apply", class: "primary-action" %>
      <%= link_to "Clear", issues_path, class: "secondary-action" %>
    </div>

  <% end %>

  <% if @status.present? || @project_id.present? || @query.present? || @tag_id.present? %>
    <section class="filter-summary">
      <p>Showing filtered results</p>
      <%= link_to "Clear filters", issues_path %>
    </section>
  <% end %>
</section>