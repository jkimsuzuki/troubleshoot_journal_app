<%= form_with(model: issue) do |form| %>
  <% if issue.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(issue.errors.count, "error") %> prohibited this issue from being saved:</h2>

      <ul>
        <% issue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div><br>

  <div>
    <%= form.label :project_name, style: "display: block" %>
    <%= form.text_field :project_name %>
  </div><br>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.text_field :status %>
  </div><br>

  <div>
    <%= form.label :error_message, style: "display: block" %>
    <%= form.textarea :error_message, rows: 4 %>
  </div><br>

  <div>
    <%= form.label :stack_trace, style: "display: block" %>
    <%= form.textarea :stack_trace, rows: 6 %>
  </div><br>

  <div>
    <%= form.label :steps_to_reproduce, style: "display: block" %>
    <%= form.textarea :steps_to_reproduce, rows: 4 %>
  </div><br>

  <div>
    <%= form.label :what_i_checked, style: "display: block" %>
    <%= form.textarea :what_i_checked, rows: 4 %>
  </div><br>

  <div>
    <%= form.label :root_cause, style: "display: block" %>
    <%= form.textarea :root_cause, rows: 6 %>
  </div><br>

  <div>
    <%= form.label :fix, style: "display: block" %>
    <%= form.textarea :fix, rows: 6 %>
  </div><br>

  <div>
    <%= form.label :prevention, style: "display: block" %>
    <%= form.textarea :prevention %>
  </div><br>

  <div>
    <%= form.label :interview_summary, style: "display: block" %>
    <%= form.textarea :interview_summary, rows: 4 %>
  </div><br>

  <div>
    <%= form.submit %>
  </div>
<% end %>
