<%= form_with(model: issue) do |form| %>

  <% if issue.errors.any? %>
    <div style="color: red">
      <h2>
        <%= pluralize(issue.errors.count, "error") %>
        prohibited this issue from being saved:
      </h2>

      <ul>
        <% issue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="form-section">

    <h2>Issue Overview</h2>

    <div class="field">
      <%= form.label :title %>
      <%= form.text_field :title %>
    </div>

    <div class="field">
      <%= form.label :project_id, "Project" %>
      <%= form.collection_select :project_id,
      Project.all,
      :id,
      :name,
      prompt: "Select a project" %>
    </div>

    <div class="field">
      <%= form.label :status %>
      <%= form.select :status,
      ["Pending", "Investigating", "Resolved"] %>
    </div>

  </section>

  <section class="form-section">

    <h2>Error Details</h2>

    <div class="field">
      <%= form.label :error_message %>
      <%= form.text_area :error_message, rows: 4 %>
    </div>

    <div class="field">
      <%= form.label :stack_trace %>
      <%= form.text_area :stack_trace, rows: 6 %>
    </div>

    <div class="field">
      <%= form.label :steps_to_reproduce %>
      <%= form.text_area :steps_to_reproduce, rows: 4 %>
    </div>

  </section>

  <section class="form-section">

    <h2>Investigation Process</h2>

    <div class="field">
      <%= form.label :what_i_checked %>
      <%= form.text_area :what_i_checked, rows: 4 %>
    </div>

    <div class="field">
      <%= form.label :root_cause %>
      <%= form.text_area :root_cause, rows: 4 %>
    </div>

    <div class="field">
      <%= form.label :fix %>
      <%= form.text_area :fix, rows: 4 %>
    </div>

    <div class="field">
      <%= form.label :prevention %>
      <%= form.text_area :prevention, rows: 4 %>
    </div>

    <div class="field">
      <%= form.label :interview_summary %>
      <%= form.text_area :interview_summary, rows: 4 %>
    </div>

  </section>

  <div class="form-actions">
    <%= form.submit %>
  </div>

<% end %>
