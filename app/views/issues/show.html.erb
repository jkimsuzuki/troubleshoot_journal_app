<p style="color: green"><%= notice %></p>

<section class="issue-detail-page">

  <div class="issue-detail-header">
    <div>
      <h1><%= @issue.title %></h1>

      <p class="issue-meta">
        Project:
        <%= @issue.project&.name || "No project assigned" %>
      </p>

      <p class="issue-meta">
        Created:
        <%= @issue.created_at.strftime("%B %d, %Y") %>
      </p>
    </div>

    <span class="status-badge">
      <%= @issue.status %>
    </span>
  </div>

  <section class="detail-section">
    <h2>Error Message</h2>
    <p><%= @issue.error_message %></p>
  </section>

  <section class="detail-section">
    <h2>Stack Trace</h2>

    <pre class="stack-trace">
<%= @issue.stack_trace %>
    </pre>
  </section>

  <section class="detail-section">
    <h2>Steps to Reproduce</h2>
    <p><%= @issue.steps_to_reproduce %></p>
  </section>

  <section class="detail-section">
    <h2>What I Checked</h2>
    <p><%= @issue.what_i_checked %></p>
  </section>

  <section class="detail-section">
    <h2>Root Cause</h2>
    <p><%= @issue.root_cause %></p>
  </section>

  <section class="detail-section">
    <h2>Fix</h2>
    <p><%= @issue.fix %></p>
  </section>

  <section class="detail-section">
    <h2>Prevention</h2>
    <p><%= @issue.prevention %></p>
  </section>

  <section class="detail-section">
    <h2>Interview Summary</h2>
    <p><%= @issue.interview_summary %></p>
  </section>

  <div class="issue-actions">
    <%= link_to "Back to issues", issues_path %>
    <%= link_to "Edit issue", edit_issue_path(@issue) %>

    <%= button_to "Delete issue",
    @issue,
    method: :delete %>
  </div>

</section>
