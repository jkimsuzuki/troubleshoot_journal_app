<p style="color: green"><%= notice %></p>

<% content_for :title, "Issues" %>

<h1>Issues</h1>

<p>
    Track, investigate, and learn from every issue.
</p>

<hr>

<div id="issues">
  <% @issues.each do |issue| %>

  <section>
    <h2>
      <%= link_to issue.title, issue %>
    </h2>

    <p>
      <strong>Project:</strong>
      <%= issue.project_name %>
    </p>

    <p>
      <strong>Status:</strong>
      <%= issue.status %>
    </p>

    <p>
      <strong>Date Created:</strong>
      <%= issue.created_at.strftime("%B %d, %Y") %>
    </p>
  </section>

    <hr>

    <%end%>

</div>

<%= link_to "New issue", new_issue_path %>
