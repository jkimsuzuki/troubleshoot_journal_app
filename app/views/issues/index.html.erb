<p style="color: green"><%= notice %></p>

<% content_for :title, "Issues" %>

<h1>Issues</h1>

<p>
    Track, investigate, and learn from every issue.
</p>

<section class="dashboard-stats">

  <div>
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
  </div>

  <div>
    <h3>Resolved Issues</h3>
    <p><%= @resolved_issues %></p>
  </div>

  <div>
    <h3>Investigating Issues</h3>
    <p><%= @investigating_issues %></p>
  </div>

  <div>
    <h3>Total Projects</h3>
    <p><%= @projects_count %></p>
  </div>

</section>
<hr>

<%= render "filter_controls" %>

<section class="section-header">
  <div>
    <h2>Issue List</h2>
    <p>Review logged troubleshooting issues and investigation status.</p>
  </div>

  <%= link_to new_issue_path, class: "primary-action" do %>
  <span>+</span>
  New Issue
  <% end %> 
</section>

<section class="dashboard-table issues-table">

  <div class="dashboard-table-header">
    <span>ID</span>
    <span>Title</span>
    <span>Project</span>
    <span>Status</span>
    <span>Severity</span>
    <span>Updated</span>
  </div>

  <% if @issues.any? %>

    <% @issues.each do |issue| %>

      <article class="dashboard-row">

        <div>
          #<%= issue.id %>
        </div>

        <div>
          <%= link_to issue.title, issue %>
        </div>

        <div>
          <%= issue.project&.name || "No project assigned" %>
        </div>

        <div>
          <span class="<%= status_badge_class(issue.status) %>">
            <%= status_label(issue.status) %>
          </span>
        </div>

        <div>
          <span class="severity-pill">
            <%= issue.severity.presence || "Not set" %>
          </span>
        </div>

        <div>
          <%= formatted_date(issue.updated_at) %>
        </div>

      </article>

    <% end %>

  <% else %>

    <section class="empty-state dashboard-empty-state">
      <h2>No issues found</h2>
      <p>Create a new issue or adjust your filters.</p>
      <%= link_to "New Issue", new_issue_path, class: "primary-action" %>
    </section>

  <% end %>

</section>