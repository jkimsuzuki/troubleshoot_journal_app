<p style="color: green"><%= notice %></p>

<% content_for :title, "Issues" %>

<h1>Issues</h1>

<p>
    Track, investigate, and learn from every issue.
</p>

<section class="dashboard-stats">

  <div>
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
  </div>

  <div>
    <h3>Resolved Issues</h3>
    <p><%= @resolved_issues %></p>
  </div>

  <div>
    <h3>Investigating Issues</h3>
    <p><%= @investigating_issues %></p>
  </div>

  <div>
    <h3>Total Projects</h3>
    <p><%= @projects_count %></p>
  </div>

</section>
<hr>

<nav class="status-filters">

  <%= link_to "All",
  issues_path(project_id: @project_id, query: @query),
  class: (@status.nil? ? "active-filter" : nil) %>

  <%= link_to "Pending",
  issues_path(status: "Pending", project_id: @project_id, query: @query),
  class: (@status == "Pending" ? "active-filter" : nil) %>

  <%= link_to "Investigating",
  issues_path(status: "Investigating", project_id: @project_id, query: @query),
  class: (@status == "Investigating" ? "active-filter" : nil) %>

  <%= link_to "Resolved",
  issues_path(status: "Resolved", project_id: @project_id, query: @query),
  class: (@status == "Resolved" ? "active-filter" : nil) %>

</nav>

<nav class="project-filters">

  <%= link_to "All Projects",
  issues_path,
  class: (@project_id.nil? ? "active-filter" : nil) %>

  <% Project.all.each do |project| %>

    <%= link_to project.name,
    issues_path(project_id: project.id),
    class: (@project_id == project.id.to_s ? "active-filter" : nil) %>

  <% end %>

</nav>

<form class="search-form" method="get" action="/issues">

<%= hidden_field_tag :status, @status if @status.present? %>
<%= hidden_field_tag :project_id, @project_id if @project_id.present? %>

  <%= text_field_tag :query,
  params[:query],
  placeholder: "Search issues..." %>

  <%= submit_tag "Search" %>

</form>

<div id="issues">
  <% if @issues.any? %>

    <% @issues.each do |issue| %>
      <%= render "issue_card", issue: issue %>
      <%end%>

  <% else %>

  <section class="empty-state">

    <h2>No issues found</h2>

    <p>
      Try changing filters or create a new issue.
    </p>

    <%= link_to "Create issue", new_issue_path %>

  </section>

<% end %>

</div>

<%= link_to "New issue", new_issue_path %>
