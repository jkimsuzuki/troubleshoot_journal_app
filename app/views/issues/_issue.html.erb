<div id="<%= dom_id issue %>">
  <div>
    <strong>Title:</strong>
    <%= issue.title %>
  </div>

  <div>
    <strong>Project name:</strong>
    <%= issue.project&.name || "No project assigned" %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= issue.status %>
  </div>

  <div>
    <strong>Error message:</strong>
    <%= issue.error_message %>
  </div>

  <div>
    <strong>Stack trace:</strong>
    <%= issue.stack_trace %>
  </div>

  <div>
    <strong>Steps to reproduce:</strong>
    <%= issue.steps_to_reproduce %>
  </div>

  <div>
    <strong>What I checked:</strong>
    <%= issue.what_i_checked %>
  </div>

  <div>
    <strong>Root cause:</strong>
    <%= issue.root_cause %>
  </div>

  <div>
    <strong>Fix:</strong>
    <%= issue.fix %>
  </div>

  <div>
    <strong>Prevention:</strong>
    <%= issue.prevention %>
  </div>

  <div>
    <strong>Interview summary:</strong>
    <%= issue.interview_summary %>
  </div>

</div>
