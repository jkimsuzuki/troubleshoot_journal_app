<section class="issue-card">

  <div class="issue-card-header">
    <h2 class="issue-title">
      <%= link_to issue.title, issue %>
    </h2>

    <span class="<%= status_badge_class(issue.status) %>">
       <%= issue.status %>
    </span>

    <span class="<%= severity_badge_class(issue.severity) %>">
       <%= issue.severity %>
    </span>
  </div>

<div class="issue-card-body">
  <div class="issue-meta">

  <div class="issue-meta-item">
    <strong>Project:</strong>
    <%= issue.project&.name || "No project assigned" %>
  </div>

  <div class="issue-meta-item">
    <strong>Created:</strong>
    <%= formatted_date(issue.created_at) %>
  </div>

  <% if issue.tags.any? %>
  <div class="issue-tags">
    <% issue.tags.each do |tag| %>
      <%= link_to tag.name, tag_path(tag), class: "tag-pill" %>
    <% end %>
  </div>
<% end %>
</div>

</div>
</section>

