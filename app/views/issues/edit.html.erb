<% content_for :title, "Edit Issue" %>

<section class="page-header">
  <div>
    <h1>Edit Issue</h1>
    <p>Update troubleshooting details, investigation notes, status, severity, and tags.</p>
  </div>
</section>

<%= render "form", issue: @issue %>

<div class="issue-actions">
  <%= link_to "Show issue", @issue, class: "secondary-action" %>
  <%= link_to "Back to issues", issues_path, class: "secondary-action" %>
</div>