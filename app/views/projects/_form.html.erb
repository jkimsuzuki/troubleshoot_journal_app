<%= form_with(model: project) do |form| %>
  <% if project.errors.any? %>
    <div style="color: red">
      <h2>
        <%= pluralize(project.errors.count, "error") %>
        prohibited this project from being saved:
      </h2>

      <ul>
        <% project.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="form-section">
    <h2>Project Details</h2>

    <div class="field">
      <%= form.label :name %>
      <%= form.text_field :name %>
    </div>

    <div class="field">
      <%= form.label :description %>
      <%= form.text_area :description, rows: 5 %>
    </div>

    <div class="field">
      <%= form.label :status %>
      <%= form.select :status, ["Active", "Paused", "Completed"], prompt: "Select status" %>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit project.persisted? ? "Update Project" : "Create Project" %>
    <%= link_to "Cancel", projects_path, class: "secondary-action" %>
  </div>
<% end %>