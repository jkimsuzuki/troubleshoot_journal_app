<p style="color: green"><%= notice %></p>

<% content_for :title, @project.name %>

<section class="project-detail-page">

  <section class="page-header">
    <div>
      <h1><%= @project.name %></h1>
      <p><%= @project.description %></p>
    </div>

    <span class="status-badge">
      <%= @project.status %>
    </span>
  </section>

  <section class="dashboard-stats">
    <div>
      <h3>Total Issues</h3>
      <p><%= @project.issues.count %></p>
    </div>

    <div>
      <h3>Resolved</h3>
      <p><%= @project.issues.where(status: "Resolved").count %></p>
    </div>

    <div>
      <h3>Investigating</h3>
      <p><%= @project.issues.where(status: "Investigating").count %></p>
    </div>
  </section>

  <section>
    <h2>Issues for this project</h2>

    <% if @project.issues.any? %>
      <% @project.issues.each do |issue| %>
        <%= render "issues/issue_card", issue: issue %>
      <% end %>
    <% else %>
      <section class="empty-state">
        <h2>No issues yet</h2>
        <p>No troubleshooting issues have been logged for this project yet.</p>
      </section>
    <% end %>
  </section>

  <div class="issue-actions">
    <%= link_to "Back to projects", projects_path, class: "secondary-action" %>
   <%= link_to "Edit project", edit_project_path(@project), class: "secondary-action" %>
    <%= button_to "Delete project",
  project_path(@project),
  method: :delete,
  class: "secondary-action",
  form_class: "inline-button-form",
  data: { turbo_confirm: "Are you sure you want to delete this project?" } %>
  </div>

</section>