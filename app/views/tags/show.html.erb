<% content_for :title, @tag.name %>

<section class="page-header">
  <div>
    <h1><%= @tag.name %></h1>
    <p>Issues categorized under this troubleshooting tag.</p>
  </div>
</section>

<section class="dashboard-stats">
  <div>
    <h3>Total Issues</h3>
    <p><%= @tag.issues.count %></p>
  </div>

  <div>
    <h3>Resolved</h3>
    <p><%= @tag.issues.where(status: "Resolved").count %></p>
  </div>

  <div>
    <h3>Investigating</h3>
    <p><%= @tag.issues.where(status: "Investigating").count %></p>
  </div>
</section>

<% if @tag.issues.any? %>
  <% @tag.issues.each do |issue| %>
    <%= render "issues/issue_card", issue: issue %>
  <% end %>
<% else %>
  <section class="empty-state">
    <h2>No issues for this tag yet</h2>
    <p>This tag has not been attached to any troubleshooting issues.</p>
  </section>
<% end %>

<div class="issue-actions">
  <%= link_to "Back to tags", tags_path %>
</div>
