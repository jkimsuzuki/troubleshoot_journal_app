<% content_for :title, "Reports" %>

<section class="page-header reports-page-header">
  <div>
    <h1>Reports</h1>
    <p>Live observability and analytics from your troubleshooting data.</p>
  </div>
</section>

<section class="report-card grafana-embed-card">
  <div class="report-card-header">
    <div>
      <h2>Operational Dashboard</h2>
      <p>
        Live production metrics from SignalDesk, collected through Prometheus
        and visualized with self-hosted Grafana.
      </p>
    </div>
  </div>

  <div class="grafana-frame-wrapper">
  <iframe
  src="https://p01--signaldesk-grafana--w2hqm5zlsbps.code.run/d/signaldesk-observability/signaldesk-observability?orgId=1&from=now-30d&to=now&timezone=browser&kiosk"
  width="100%"
  height="1500"
  frameborder="0">
</iframe>
  </div>
</section>

<section class="dashboard-stats reports-summary-stats">
  <div class="dashboard-panel">
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
    <span>All recorded issues</span>
  </div>

  <div class="dashboard-panel">
    <h3>Resolved Issues</h3>
    <p><%= @resolved_issues %></p>
    <span>Completed investigations</span>
  </div>

  <div class="dashboard-panel">
    <h3>Resolution Rate</h3>
    <p><%= @resolution_rate %>%</p>
    <span>Resolved / total</span>
  </div>

  <div class="dashboard-panel">
    <h3>Active Issues</h3>
    <p><%= @investigating_issues + @pending_issues %></p>
    <span>Open investigations</span>
  </div>
</section>

<section class="reports-bottom-grid">
  <section class="report-card">
    <h2>Issues by Project</h2>

    <div class="mini-table">
      <% @projects_report.each do |project| %>
        <% total = project.issues.count %>
        <% resolved = project.issues.where(status: "Resolved").count %>
        <% rate = total.positive? ? ((resolved.to_f / total) * 100).round : 0 %>

        <div class="mini-table-row">
          <span><%= project.name %></span>
          <span><%= total %> issues</span>
          <span><%= rate %>% resolved</span>
          <div class="mini-progress-track">
            <div class="mini-progress-fill" style="width: <%= rate %>%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <%= link_to "View all projects →", projects_path, class: "report-link" %>
  </section>

  <section class="report-card">
    <h2>Top Tags</h2>

    <div class="mini-table">
      <% @top_tags.each do |tag| %>
        <% count = tag.issues.count %>
        <% width = @max_tag_count.positive? ? ((count.to_f / @max_tag_count) * 100).round : 0 %>

        <div class="mini-table-row">
          <span><%= tag.name %></span>
          <span><%= count %> issues</span>
          <div class="mini-progress-track">
            <div class="mini-progress-fill" style="width: <%= width %>%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <%= link_to "View all tags →", tags_path, class: "report-link" %>
  </section>
</section>