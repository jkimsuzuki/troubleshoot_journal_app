<% content_for :title, "Reports" %>

<section class="page-header">
  <div>
    <h1>Reports</h1>
    <p>Review troubleshooting patterns, issue status, and project activity.</p>
  </div>
</section>

<section class="dashboard-stats">
  <div>
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
  </div>

  <div>
    <h3>Resolved</h3>
    <p><%= @resolved_issues %></p>
  </div>

  <div>
    <h3>Investigating</h3>
    <p><%= @investigating_issues %></p>
  </div>

  <div>
    <h3>Pending</h3>
    <p><%= @pending_issues %></p>
  </div>
</section>

<section class="report-section">
  <h2>Issues by Severity</h2>

  <div class="report-list">
    <div class="report-row">
      <div>
        <strong>Critical</strong>
        <p>Highest priority troubleshooting issues</p>
      </div>
      <span><%= pluralize(@critical_severity, "issue") %></span>
    </div>

    <div class="report-row">
      <div>
        <strong>High</strong>
        <p>Important issues that need close attention</p>
      </div>
      <span><%= pluralize(@high_severity, "issue") %></span>
    </div>

    <div class="report-row">
      <div>
        <strong>Medium</strong>
        <p>Normal priority troubleshooting issues</p>
      </div>
      <span><%= pluralize(@medium_severity, "issue") %></span>
    </div>

    <div class="report-row">
      <div>
        <strong>Low</strong>
        <p>Lower priority learning or cleanup issues</p>
      </div>
      <span><%= pluralize(@low_severity, "issue") %></span>
    </div>
  </div>
</section>

<section class="reports-grid">
  <section class="report-section">
    <h2>Issues by Project</h2>

    <% if @projects.any? %>
      <div class="report-list">
        <% @projects.each do |project| %>
          <div class="report-row">
            <div>
              <strong><%= link_to project.name, project %></strong>
              <p><%= project.description %></p>
            </div>

            <span>
              <%= pluralize(project.issues.count, "issue") %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <section class="empty-state">
        <h2>No projects yet</h2>
        <p>Create projects to begin tracking troubleshooting patterns.</p>
      </section>
    <% end %>
  </section>

  <section class="report-section">
    <h2>Issues by Tag</h2>

    <% if @tags.any? %>
      <div class="report-list">
        <% @tags.each do |tag| %>
          <div class="report-row">
            <div>
              <strong><%= link_to tag.name, tag %></strong>
              <p>Troubleshooting category</p>
            </div>

            <span>
              <%= pluralize(tag.issues.count, "issue") %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <section class="empty-state">
        <h2>No tags yet</h2>
        <p>Add tags to organize troubleshooting patterns.</p>
      </section>
    <% end %>
  </section>
</section>