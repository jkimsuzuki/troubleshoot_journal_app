<% content_for :title, "Timeline" %>

<section class="page-header">
  <div>
    <h1>Timeline</h1>
    <p>View a chronological timeline of troubleshooting activity.</p>
  </div>
</section>

<section class="filter-panel">
  <%= form_with url: timeline_path, method: :get, local: true, class: "filter-form timeline-filter-form" do |form| %>

    <div class="filter-field filter-search">
      <%= form.label :query, "Search" %>
      <%= form.text_field :query, value: @query, placeholder: "Search timeline..." %>
    </div>

    <div class="filter-field">
      <%= form.label :project_id, "Project" %>
      <%= form.collection_select :project_id,
        Project.order(:name),
        :id,
        :name,
        { include_blank: "All Projects", selected: @project_id }
      %>
    </div>

    <div class="filter-field">
      <%= form.label :status, "Status" %>
      <%= form.select :status,
        options_for_select(
          [
            ["All Statuses", ""],
            ["Pending", "Pending"],
            ["Active", "Investigating"],
            ["Resolved", "Resolved"]
          ],
          @status
        )
      %>
    </div>

    <div class="filter-actions">
      <%= form.submit "Apply", class: "primary-action" %>
      <%= link_to "Clear", timeline_path, class: "secondary-action" %>
    </div>

  <% end %>
</section>

<section class="timeline-v2">

  <% if @grouped_issues.any? %>

    <% @grouped_issues.each do |date, issues| %>

      <section class="timeline-date-group">

        <h2 class="timeline-date-heading">
          <%= date.strftime("%B %d, %Y") %>
        </h2>

        <% issues.each do |issue| %>

          <article class="timeline-v2-row">

            <div class="timeline-time">
              <%= issue.updated_at.strftime("%I:%M %p") %>
            </div>

            <div class="timeline-dot"></div>

            <div class="timeline-event">
              <%= link_to issue_path(issue) do %>
                Updated issue #<%= issue.id %> “<%= issue.title %>”
              <% end %>
            </div>

            <div>
              <span class="<%= status_badge_class(issue.status) %>">
                <%= status_label(issue.status) %>
              </span>
            </div>

            <div>
              <span class="severity-pill">
                <%= issue.project&.name || "No project" %>
              </span>
            </div>

          </article>

        <% end %>

      </section>

    <% end %>

  <% else %>

    <section class="empty-state">
      <h2>No timeline activity found</h2>
      <p>Create or update issues to build your troubleshooting timeline.</p>
      <%= link_to "New Issue", new_issue_path, class: "primary-action" %>
    </section>

  <% end %>

</section>