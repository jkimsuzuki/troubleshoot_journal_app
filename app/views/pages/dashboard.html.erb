<% content_for :title, "Dashboard" %>

<section class="page-header">
  <div>
    <h1>Dashboard</h1>
    <p>Track investigations, troubleshooting progress, and operational activity.</p>
  </div>

  <%= link_to "New Issue", new_issue_path, class: "primary-action" %>
</section>

<section class="dashboard-stats">
  <div class="dashboard-panel">
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
    <span>All time</span>
  </div>

  <div class="dashboard-panel">
    <h3>Investigating</h3>
    <p><%= @investigating_issues %></p>
    <span>Currently open</span>
  </div>

  <div class="dashboard-panel">
    <h3>Resolved</h3>
    <p><%= @resolved_issues %></p>
    <span>Closed issues</span>
  </div>

  <div class="dashboard-panel">
    <h3>Projects</h3>
    <p><%= @projects.count %></p>
    <span>Total projects</span>
  </div>

</section>

<section class="dashboard-layout">

  <section class="dashboard-main">

    <section class="dashboard-toolbar">

      <nav class="status-filters">
        <%= link_to "All Issues", issues_path %>
        <%= link_to "Investigating", issues_path(status: "Investigating") %>
        <%= link_to "Resolved", issues_path(status: "Resolved") %>
      </nav>

      <%= form_with url: issues_path,
      method: :get,
      local: true,
      class: "dashboard-search" do |form| %>

        <%= form.text_field :query,
        placeholder: "Search issues..." %>

      <% end %>

    </section>

    <section class="section-header dashboard-section-header">
      <div>
        <h2>Recent Issues</h2>
        <p>Latest troubleshooting records and investigation status.</p>
      </div>

        <%= link_to "View All Issues", issues_path, class: "secondary-action" %>
    </section>

    <section class="dashboard-table">

      <div class="dashboard-table-header">
        <span>ID</span>
        <span>Title</span>
        <span>Project</span>
        <span>Status</span>
        <span>Severity</span>
        <span>Updated</span>
      </div>

      <% if @recent_issues.any? %>

  <% @recent_issues.each do |issue| %>

    <article class="dashboard-row">

      <div>
        #<%= issue.id %>
      </div>

      <div>
        <%= link_to issue.title, issue %>
      </div>

      <div>
        <%= issue.project&.name || "No project assigned" %>
      </div>

      <div>
        <span class="<%= status_badge_class(issue.status) %>">
          <%= status_label(issue.status) %>
        </span>
      </div>

      <div>
        <span class="severity-pill">
          <%= issue.severity.presence || "Not set" %>
        </span>
      </div>

      <div>
        <%= formatted_date(issue.updated_at) %>
      </div>

    </article>

  <% end %>

<% else %>

  <section class="empty-state dashboard-empty-state">
    <h2>No recent issues</h2>
    <p>Create your first issue to start building your troubleshooting history.</p>
    <%= link_to "New Issue", new_issue_path, class: "primary-action" %>
  </section>

<% end %>

    </section>

  </section>

  <aside class="dashboard-sidebar">

    <section class="dashboard-side-panel">
      <h2>What this app tracks</h2>

      <ul>
        <li>Issue investigations</li>
        <li>Root causes</li>
        <li>Fixes and prevention</li>
        <li>Project troubleshooting history</li>
        <li>Interview-ready debugging stories</li>
      </ul>
    </section>

    <section class="dashboard-side-panel">
      <h2>Tech Stack</h2>

      <ul>
        <li>Ruby on Rails</li>
        <li>SQLite</li>
        <li>ERB views</li>
        <li>Custom CSS</li>
        <li>Minitest</li>
        <li>GitHub Actions</li>
      </ul>
    </section>

   

  </aside>

</section>
