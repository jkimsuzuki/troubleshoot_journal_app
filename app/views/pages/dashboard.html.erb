<% content_for :title, "Dashboard" %>

<section class="page-header">
  <div>
    <h1>Dashboard</h1>
    <p>Review troubleshooting activity, issue status, and project coverage.</p>
  </div>
</section>

<section class="dashboard-stats">
  <div>
    <h3>Total Issues</h3>
    <p><%= @total_issues %></p>
  </div>

  <div>
    <h3>Resolved</h3>
    <p><%= @resolved_issues %></p>
  </div>

  <div>
    <h3>Investigating</h3>
    <p><%= @investigating_issues %></p>
  </div>

  <div>
    <h3>Pending</h3>
    <p><%= @pending_issues %></p>
  </div>
</section>

<section class="quick-actions">
  <%= link_to "New Issue", new_issue_path, class: "primary-action" %>
  <%= link_to "View All Issues", issues_path, class: "secondary-action" %>
  <%= link_to "View Reports", reports_path, class: "secondary-action" %>
</section>

<section class="report-section">
  <h2>Recent Issues</h2>

  <% if @recent_issues.any? %>
    <% @recent_issues.each do |issue| %>
      <%= render "issues/issue_card", issue: issue %>
    <% end %>
  <% else %>
    <section class="empty-state">
      <h2>No issues yet</h2>
      <p>Create your first issue to begin tracking troubleshooting activity.</p>
    </section>
  <% end %>
</section>
